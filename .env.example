# ============================================
# SaaS Factory - Variables de Entorno
# ============================================
# Copia este archivo como .env.local para desarrollo
# o configura estas variables en tu plataforma de despliegue

# --- Deploy Target ---
# Valores: "vercel" | "easypanel"
# Controla configuración condicional en next.config.ts
# En Vercel no necesitas setear esto (default: vercel)
# En EasyPanel: setear a "easypanel"
DEPLOY_TARGET="vercel"

# --- App ---
# URL pública de la aplicación (sin trailing slash)
# Vercel: se autoconfigura via VERCEL_URL
# EasyPanel: debes configurar manualmente
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Puerto del servidor (solo aplica en self-hosted)
PORT=3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- AI (OpenRouter) ---
OPENROUTER_API_KEY="your-openrouter-key"
